generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Better-Auth Core Tables ───

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  sessions      Session[]
  accounts      Account[]
  settings      UserSettings?
  preferences   UserPreferences?
  deezerCred    DeezerCredential?
  playlists     Playlist[]
  downloads     DownloadHistory[]
  albums        Album[]
  sharedTracks  SharedTrack[]
  recentPlays   RecentPlay[]

  @@map("user")
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("account")
}

model Verification {
  id         String    @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime? @default(now())
  updatedAt  DateTime? @updatedAt

  @@map("verification")
}

// ─── Legacy Config Table (used by Spotify plugin & global settings) ───

model Config {
  userId    String   @default("default") @map("user_id")
  key       String
  value     Json
  updatedAt DateTime @default(now()) @map("updated_at") @db.Timestamptz

  @@id([userId, key])
  @@map("config")
}

// ─── Application Tables ───

model DeezerCredential {
  id                String   @id @default(cuid())
  userId            String   @unique
  arl               String
  deezerUserId      BigInt?
  deezerUserName    String?
  deezerPicture     String?
  canStreamHq       Boolean  @default(false)
  canStreamLossless Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("deezer_credential")
}

model UserSettings {
  id       String @id @default(cuid())
  userId   String @unique
  settings Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_settings")
}

model UserPreferences {
  id          String   @id @default(cuid())
  userId      String   @unique
  preferences Json     @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_preferences")
}

model Playlist {
  id          String   @id @default(cuid())
  userId      String
  title       String
  description String?
  coverUrl    String?
  isPublic    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user   User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  tracks PlaylistTrack[]

  @@map("playlist")
}

model PlaylistTrack {
  id         String   @id @default(cuid())
  playlistId String
  trackId    String
  title      String
  artist     String
  album      String?
  coverUrl   String?
  duration   Int?
  position   Int
  addedAt    DateTime @default(now())

  playlist Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)

  @@unique([playlistId, trackId])
  @@map("playlist_track")
}

model Album {
  id             String   @id @default(cuid())
  userId         String
  deezerAlbumId  String
  title          String
  artist         String
  coverUrl       String?
  trackCount     Int      @default(0)
  downloadedAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, deezerAlbumId])
  @@index([userId])
  @@map("album")
}

model StoredTrack {
  id          String   @id @default(cuid())
  trackId     String
  bitrate     Int
  storagePath String
  storageType String
  fileSize    Int?
  createdAt   DateTime @default(now())

  downloads    DownloadHistory[]
  sharedTracks SharedTrack[]

  @@unique([trackId, bitrate])
  @@index([trackId])
  @@map("stored_track")
}

model DownloadHistory {
  id             String   @id @default(cuid())
  userId         String
  trackId        String
  title          String
  artist         String
  album          String?
  albumId        String?
  coverUrl       String?
  bitrate        Int
  fileSize       Int?
  storagePath    String?
  storageType    String
  storedTrackId  String?
  downloadedAt   DateTime @default(now())

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  storedTrack StoredTrack? @relation(fields: [storedTrackId], references: [id])

  @@unique([userId, trackId])
  @@index([userId])
  @@index([trackId])
  @@index([storedTrackId])
  @@map("download_history")
}

// ─── Recent Plays (Spotify-like history; tracks counted only after ≥30s playback) ───

model RecentPlay {
  id        String   @id @default(cuid())
  userId    String
  trackId   String
  title     String
  artist    String
  album     String?
  albumId   String?
  coverUrl  String?
  duration  Int?
  playedAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, trackId])
  @@index([userId, playedAt(sort: Desc)])
  @@map("recent_play")
}

// ─── Track Sharing ───

model SharedTrack {
  id            String    @id @default(cuid())
  shareId       String    @unique
  trackId       String
  userId        String
  title         String
  artist        String
  album         String?
  coverUrl      String?
  duration      Int?
  storedTrackId String
  expiresAt     DateTime?
  plays         Int       @default(0)
  createdAt     DateTime  @default(now())

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  storedTrack StoredTrack @relation(fields: [storedTrackId], references: [id])

  @@index([userId])
  @@map("shared_track")
}
