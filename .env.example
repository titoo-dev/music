# ── Docker inter-service communication (required) ──
WS_BROADCAST_URL=http://ws:6595
NEXT_URL=http://web:3000
WS_PORT=6595

# ── PostgreSQL (required) ──
DATABASE_URL=postgresql://deemix:deemix@postgres:5432/deemix
POSTGRES_USER=deemix
POSTGRES_PASSWORD=deemix
POSTGRES_DB=deemix

# ── Client-side WebSocket (set at build time) ──
# NEXT_PUBLIC_WS_URL=wss://music-ws.titosy.dev
# NEXT_PUBLIC_WS_PORT=6595

# ── S3 / MinIO storage ──
# DEEMIX_STORAGE_TYPE=s3
# DEEMIX_S3_ENDPOINT=http://minio:9000
# DEEMIX_S3_REGION=us-east-1
# DEEMIX_S3_BUCKET=deemix-music
# DEEMIX_S3_ACCESS_KEY=minioadmin
# DEEMIX_S3_SECRET_KEY=minioadmin
# DEEMIX_S3_PATH_PREFIX=

# ── MinIO ──
# MINIO_ROOT_USER=minioadmin
# MINIO_ROOT_PASSWORD=minioadmin

# ── Better Auth ──
BETTER_AUTH_SECRET=change-me-to-a-random-64-char-secret-key-for-production
BETTER_AUTH_URL=http://localhost:3000
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── Guest browsing (optional: shared Deezer ARL for unauthenticated users) ──
# DEEMIX_SERVICE_ARL=
